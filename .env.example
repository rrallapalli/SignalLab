# ─────────────────────────────────────────────────────────────────────
#  SignalLab secrets — template
#
#  You do NOT need to edit this file by hand.
#  Run `python setup_secrets.py` (or just double-click the start file)
#  and the wizard will create a real `.env` for you.
#
#  If you prefer doing it manually: copy this to `.env` and fill it in.
#  `.env` is git-ignored — never commit it.
# ─────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────
# Used for both reasoning (signal agents) and embeddings.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# gpt-4o-mini = cheap + fast · gpt-4o = higher quality reasoning.
OPENAI_MODEL=gpt-4o-mini

# Used to index documents into ChromaDB.
EMBED_MODEL=text-embedding-3-small

# ── Advanced (safe defaults — edit only if you know why) ──────────────
# Keep at 0.0 for deterministic, evidence-grounded signals.
OPENAI_TEMPERATURE=0.0

# Days after quarter-end to keep looking for results/decks/transcripts.
NSE_BSE_RESULT_LAG_DAYS=90

# Annual reports land much later (around the AGM).
NSE_BSE_ANNUAL_LAG_DAYS=200

# Cap on documents ingested per quarter.
NSE_BSE_MAX_DOCS_PER_QUARTER=15

# Announcement listing pages to page through per exchange.
NSE_BSE_MAX_PAGES=5

# NSE/BSE ingestion needs no API key — corporate filings are public.
